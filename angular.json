{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "optimized-virtual-scroll": {
      "projectType": "library",
      "root": "projects/optimized-virtual-scroll",
      "sourceRoot": "projects/optimized-virtual-scroll/src",
      "prefix": "ovs",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/optimized-virtual-scroll/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/optimized-virtual-scroll/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/optimized-virtual-scroll/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/optimized-virtual-scroll/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    },
    "benchmark-kit": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/benchmark-kit",
      "sourceRoot": "projects/benchmark-kit/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/benchmark-kit",
            "index": "projects/benchmark-kit/src/index.html",
            "browser": "projects/benchmark-kit/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/benchmark-kit/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/benchmark-kit/public"
              }
            ],
            "styles": [
              "projects/benchmark-kit/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "benchmark-kit:build:production"
            },
            "development": {
              "buildTarget": "benchmark-kit:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "projects/benchmark-kit/tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/benchmark-kit/public"
              }
            ],
            "styles": [
              "projects/benchmark-kit/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    },
    "benchmark-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/benchmark-app",
      "sourceRoot": "projects/benchmark-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/benchmark-app",
            "index": "projects/benchmark-app/src/index.html",
            "browser": "projects/benchmark-app/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/benchmark-app/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/benchmark-app/public"
              }
            ],
            "styles": [
              "projects/benchmark-app/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "benchmark-app:build:production"
            },
            "development": {
              "buildTarget": "benchmark-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "projects/benchmark-app/tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/benchmark-app/public"
              }
            ],
            "styles": [
              "projects/benchmark-app/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    }
  }
}
